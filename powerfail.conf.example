# Telegram notifications for powerfail-shutdown
# Скопируй этот файл в /etc/powerfail/powerfail.conf и заполни свои данные
# Этот файл добавлен в .gitignore — не попадёт в репозиторий

# Telegram
# TG_BOT_TOKEN="***"
# TG_CHAT_ID="123456789"

# SOCKS5 прокси (опционально — если прямой https://api.telegram.org недоступен)
# TG_PROXY="socks5h://192.168.1.100:1080"
